# ============================================================
# Constellation 环境变量配置模板
# 复制此文件为 .env 并填入你的实际值
# ============================================================

# ---- LLM Configuration ----
# 支持 DeepSeek / OpenAI / Claude 等任何兼容 OpenAI 协议的模型
LLM_MODEL=deepseek-chat
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ---- Skeleton Compressor Configuration ----
# I帧/P帧截断参数
SKELETON_HEAD_CHARS=30
SKELETON_TAIL_CHARS=30
# 游程编码折叠 (RLE)
SKELETON_ENABLE_RLE=true
SKELETON_RLE_THRESHOLD=3
SKELETON_MAX_RLE_GROUP=10

# ---- Sliding Window Configuration ----
# 超长文档 Map-Reduce 分片参数
SLIDING_WINDOW_THRESHOLD=500    # 超过多少个 Block 启用滑动窗口
WINDOW_SIZE=300                 # 每个窗口包含的 Block 数量
WINDOW_OVERLAP=50               # 窗口间重叠的 Block 数量

# ---- Fuzzy Anchoring Configuration ----
# 模糊锚定纠偏参数
FUZZY_ANCHOR_RADIUS=5           # 搜索半径 [-N, +N]
FUZZY_MIN_SIMILARITY=0.4        # 最低 Levenshtein 相似度阈值

# ---- Logging ----
LOG_LEVEL=INFO
